# Constants (no need to change/fill anything)
APP_HOST=localhost
FRONTEND_DEV_PROTOCOL=https
FRONTEND_PROD_PROTOCOL=https
BACKEND_PROTOCOL=http
BACKEND_PORT=5000
FRONTEND_DEV_PORT=5173
FRONTEND_PROD_PORT=443
SPRING_PROFILES_ACTIVE=prod
SPRING_FRONTEND_URLS=${FRONTEND_DEV_PROTOCOL}://${APP_HOST}:${FRONTEND_DEV_PORT},${FRONTEND_PROD_PROTOCOL}://${APP_HOST}:${FRONTEND_PROD_PORT}, https://${APP_HOST}
PROXY_TARGET=${BACKEND_PROTOCOL}://backend:${BACKEND_PORT}
# Backend URL for Frontend
VITE_API_BASE_URL=/api


# Database (fill in any db password)
DB_URL=jdbc:mysql://mysql-db:3306/planent?useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here


# Security (fill in a jwt secret key)
JWT_SECRET_KEY=your_secure_256_bit_jwt_secret_key_here
# 1 hour expiration
JWT_EXPIRATION_MS=3600000


# Third-Party APIs (fill in geoapify api key)
VITE_GEOAPIFY_API_KEY=your_geoapify_api_key_here