# Ports
BACKEND_PORT=5000
FRONTEND_DEV_PORT=5173
FRONTEND_PROD_PORT=8080

# Constants
APP_HOST=localhost
FRONTEND_DEV_PROTOCOL=https
FRONTEND_PROD_PROTOCOL=https

PROXY_TARGET=http://host.docker.internal:${BACKEND_PORT}
BACKEND_PROTOCOL=http
SPRING_PROFILES_ACTIVE=dev


# CORS URLs for Backend
SPRING_FRONTEND_URLS=${FRONTEND_DEV_PROTOCOL}://${APP_HOST}:${FRONTEND_DEV_PORT},${FRONTEND_PROD_PROTOCOL}://${APP_HOST}:${FRONTEND_PROD_PORT}

# Backend URL for Frontend
VITE_API_BASE_URL=/api

# Database (FILL)
DB_URL=
DB_USERNAME=
DB_PASSWORD=
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_DDL_AUTO=validate


# Security (FILL)
JWT_SECRET_KEY=
# 1 hour
JWT_EXPIRATION_MS=3600000
SSL_KEYSTORE_PASSWORD=



# Third-Party APIs (FILL)
VITE_GEOAPIFY_API_KEY=